/* CORREÇÃO RESPONSIVA DEFINITIVA - SEM BARRA DE ROLAGEM */
@media (max-width: 768px) {
  /* Container principal com menos padding */
  .space-y-4 {
    gap: 0.75rem !important;
  }
  
  /* Tabela - ajuste fino */
  .overflow-x-auto {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  
  /* Células compactas */
  .overflow-x-auto td,
  .overflow-x-auto th {
    padding: 6px 6px !important;
  }
  
  /* Texto menor */
  .overflow-x-auto td {
    font-size: 0.7rem !important;
  }
  
  /* Nome quebra linha */
  .overflow-x-auto td:nth-child(2) {
    max-width: 100px;
    word-break: break-word;
    white-space: normal;
  }
  
  /* Botões menores */
  .overflow-x-auto td button {
    padding: 2px 4px !important;
    font-size: 0.65rem !important;
    margin: 0 1px !important;
  }
  
  /* Preço sem quebrar */
  .overflow-x-auto td:nth-child(3) {
    white-space: nowrap;
    font-size: 0.7rem !important;
  }
  
  /* Botão Novo item ocupa largura */
  .flex.flex-col.gap-3 > button {
    width: 100% !important;
  }
  
  /* Modal ocupa 95% da tela */
  .fixed.inset-0 .w-full.max-w-md {
    width: 95% !important;
    margin: 0 auto !important;
  }
  
  /* Inputs no modal */
  .fixed.inset-0 input {
    font-size: 16px !important;
  }
  
  /* Botões do modal empilhados */
  .fixed.inset-0 .flex.gap-3 {
    flex-direction: column !important;
    gap: 0.5rem !important;
  }
  
  .fixed.inset-0 .flex.gap-3 button {
    width: 100% !important;
  }
}

/* Para telas muito pequenas */
@media (max-width: 480px) {
  .overflow-x-auto td {
    font-size: 0.65rem !important;
    padding: 4px 3px !important;
  }
  
  .overflow-x-auto td:nth-child(2) {
    max-width: 80px;
  }
  
  .overflow-x-auto td button {
    padding: 1px 3px !important;
    font-size: 0.6rem !important;
  }
}

/* Barra de rolagem fina e discreta */
.overflow-x-auto::-webkit-scrollbar {
  height: 3px;
}

.overflow-x-auto::-webkit-scrollbar-track {
  background: #e2e8f0;
  border-radius: 10px;
}

.overflow-x-auto::-webkit-scrollbar-thumb {
  background: #c9a03d;
  border-radius: 10px;
}

/* CORREÇÃO ESPECÍFICA PARA TABELA NO CELULAR */
@media (max-width: 768px) {
  .overflow-x-auto {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  
  .overflow-x-auto table {
    min-width: 500px;
  }
  
  .overflow-x-auto td,
  .overflow-x-auto th {
    padding: 8px 6px !important;
    font-size: 12px !important;
  }
  
  .overflow-x-auto td button {
    padding: 2px 6px !important;
    font-size: 11px !important;
    margin: 0 2px !important;
  }
  
  /* Botão Novo item ocupa toda largura */
  .flex.flex-col.gap-3.sm\:flex-row.sm\:items-end.sm\:justify-between {
    flex-direction: column !important;
  }
  
  button.rounded-lg.bg-\[\#c9a03d\] {
    width: 100% !important;
  }
}

@media (max-width: 480px) {
  .overflow-x-auto td,
  .overflow-x-auto th {
    padding: 6px 4px !important;
    font-size: 11px !important;
  }
  
  .overflow-x-auto td button {
    padding: 1px 4px !important;
    font-size: 10px !important;
  }
}

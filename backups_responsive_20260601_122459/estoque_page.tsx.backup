"use client"

import { useEffect, useState } from "react"
import { supabase } from "../../lib/supabaseClient"
import { formatCurrency, normalizeText, toPositiveNumber } from "../../lib/format"
import type { Produto } from "../../lib/types"

type FormState = {
  nome: string
  quantidade: string
  quantidade_minima: string
  valor_compra: string
  valor_venda: string
}

const emptyForm: FormState = {
  nome: "",
  quantidade: "",
  quantidade_minima: "",
  valor_compra: "",
  valor_venda: "",
}

export default function EstoquePage() {
  const [produtos, setProdutos] = useState<Produto[]>([])
  const [modalAberto, setModalAberto] = useState(false)
  const [tipoItem, setTipoItem] = useState<"produto" | "servico">("produto")
  const [produtoEditando, setProdutoEditando] = useState<Produto | null>(null)
  const [form, setForm] = useState<FormState>(emptyForm)
  const [erro, setErro] = useState("")
  const [mensagem, setMensagem] = useState("")

  useEffect(() => {
    carregarProdutos()
  }, [])

  async function carregarProdutos() {
    const { data, error } = await supabase.from("produtos").select("*").order("nome")
    if (data) setProdutos(data as Produto[])
    if (error) setErro("Nao foi possivel carregar o estoque.")
  }

  async function salvarProduto() {
    setErro("")
    setMensagem("")

    const nome = normalizeText(form.nome)
    const valorVenda = toPositiveNumber(form.valor_venda)
    if (!nome || !valorVenda) {
      setErro("Informe nome e preco de venda maior que zero.")
      return
    }

    const tipoCorreto = produtoEditando?.tipo || tipoItem

    const dadosParaSalvar = {
      nome,
      tipo: tipoCorreto,
      valor_venda: valorVenda,
      quantidade: tipoCorreto === "produto" ? Math.max(0, Number(form.quantidade) || 0) : null,
      quantidade_minima: tipoCorreto === "produto" ? Math.max(0, Number(form.quantidade_minima) || 0) : null,
      valor_compra: tipoCorreto === "produto" ? Math.max(0, Number(form.valor_compra) || 0) : null,
    }

    const { data: userData } = await supabase.auth.getUser()
    if (!userData.user) {
      setErro("Sessao expirada. Entre novamente.")
      return
    }

    const { error } = produtoEditando
      ? await supabase.from("produtos").update(dadosParaSalvar).eq("id", produtoEditando.id)
      : await supabase.from("produtos").insert({ ...dadosParaSalvar, user_id: userData.user.id })

    if (error) {
      console.error("Erro detalhado:", error)
      setErro(error.message)
      return
    }

    fecharModal()
    setMensagem(produtoEditando ? "Item atualizado." : "Item cadastrado.")
    carregarProdutos()
  }

  async function excluirProduto(id: string) {
    if (!confirm("Tem certeza que deseja excluir?")) return
    const { error } = await supabase.from("produtos").delete().eq("id", id)
    if (error) setErro(error.message)
    carregarProdutos()
  }

  function abrirNovo() {
    setProdutoEditando(null)
    setTipoItem("produto")
    setForm(emptyForm)
    setModalAberto(true)
  }

  function abrirEdicao(produto: Produto) {
    setProdutoEditando(produto)
    setTipoItem(produto.tipo === "servico" ? "servico" : "produto")
    setForm({
      nome: produto.nome,
      quantidade: produto.quantidade?.toString() || "",
      quantidade_minima: produto.quantidade_minima?.toString() || "",
      valor_compra: produto.valor_compra?.toString() || "",
      valor_venda: produto.valor_venda?.toString() || "",
    })
    setModalAberto(true)
  }

  function fecharModal() {
    setModalAberto(false)
    setProdutoEditando(null)
    setForm(emptyForm)
  }

  return (
    <div className="space-y-6">
      <div className="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p className="text-sm font-medium uppercase tracking-wide text-[#c9a03d]">Cadastro</p>
          <h1 className="text-2xl font-bold text-[#17264a]">Estoque e servicos</h1>
        </div>
        <button onClick={abrirNovo} className="rounded-lg bg-[#c9a03d] px-4 py-2 font-semibold text-white hover:bg-[#b58d2c]">
          Novo item
        </button>
      </div>

      {(erro || mensagem) && (
        <div className={`rounded-lg p-3 text-sm ${erro ? "bg-red-50 text-red-700" : "bg-green-50 text-green-700"}`}>
          {erro || mensagem}
        </div>
      )}

      <div className="overflow-x-auto rounded-lg bg-white shadow-sm ring-1 ring-slate-200">
        <table className="w-full min-w-[680px]">
          <thead className="bg-[#17264a] text-white">
            <tr>
              <th className="p-3 text-left text-sm">Tipo</th>
              <th className="p-3 text-left text-sm">Nome</th>
              <th className="p-3 text-right text-sm">Preco</th>
              <th className="p-3 text-left text-sm">Acoes</th>
            </tr>
          </thead>
          <tbody>
            {produtos.map((produto) => (
              <tr key={produto.id} className="border-b border-slate-100">
                <td className="p-3 text-sm">{produto.tipo === "servico" ? "Servico" : "Produto"}</td>
                <td className="p-3 text-sm font-medium">{produto.nome}</td>
                <td className="p-3 text-right text-sm font-semibold text-green-700">{formatCurrency(produto.valor_venda)}</td>
                <td className="p-3 text-sm">
                  <button onClick={() => abrirEdicao(produto)} className="mr-3 font-semibold text-[#17264a]">Editar</button>
                  <button onClick={() => excluirProduto(produto.id)} className="font-semibold text-red-600">Excluir</button>
                </td>
              </tr>
            ))}
            {produtos.length === 0 && <tr><td colSpan={4} className="p-8 text-center text-sm text-slate-500">Nenhum item cadastrado.</td></tr>}
          </tbody>
        </table>
      </div>

      {modalAberto && (
        <div className="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/60 p-4">
          <div className="w-full max-w-md rounded-lg bg-white p-6 shadow-xl">
            <h2 className="mb-4 text-xl font-bold text-[#17264a]">{produtoEditando ? "Editar item" : "Novo item"}</h2>
            {!produtoEditando && (
              <div className="mb-4 grid grid-cols-2 gap-2">
                <button onClick={() => setTipoItem("produto")} className={`rounded-lg border py-2 font-semibold ${tipoItem === "produto" ? "border-[#17264a] bg-[#17264a] text-white" : "border-slate-300"}`}>Produto</button>
                <button onClick={() => setTipoItem("servico")} className={`rounded-lg border py-2 font-semibold ${tipoItem === "servico" ? "border-[#17264a] bg-[#17264a] text-white" : "border-slate-300"}`}>Servico</button>
              </div>
            )}
            <input type="text" placeholder="Nome" className="mb-3 w-full rounded-lg border border-slate-300 p-3" value={form.nome} onChange={(e) => setForm({ ...form, nome: e.target.value })} />
            {tipoItem === "produto" && (
              <>
                <div className="mb-3 grid grid-cols-2 gap-2">
                  <input type="number" min="0" placeholder="Quantidade" className="rounded-lg border border-slate-300 p-3" value={form.quantidade} onChange={(e) => setForm({ ...form, quantidade: e.target.value })} />
                  <input type="number" min="0" placeholder="Qtd minima" className="rounded-lg border border-slate-300 p-3" value={form.quantidade_minima} onChange={(e) => setForm({ ...form, quantidade_minima: e.target.value })} />
                </div>
                <input type="number" min="0" step="0.01" placeholder="Preco compra" className="mb-3 w-full rounded-lg border border-slate-300 p-3" value={form.valor_compra} onChange={(e) => setForm({ ...form, valor_compra: e.target.value })} />
              </>
            )}
            <input type="number" min="0" step="0.01" placeholder="Preco venda" className="mb-4 w-full rounded-lg border border-slate-300 p-3" value={form.valor_venda} onChange={(e) => setForm({ ...form, valor_venda: e.target.value })} />
            <div className="flex gap-3">
              <button onClick={salvarProduto} className="flex-1 rounded-lg bg-[#17264a] py-2 font-semibold text-white">Salvar</button>
              <button onClick={fecharModal} className="flex-1 rounded-lg bg-slate-200 py-2 font-semibold text-slate-700">Cancelar</button>
            </div>
          </div>
        </div>
      )}
    </div>
  )
}
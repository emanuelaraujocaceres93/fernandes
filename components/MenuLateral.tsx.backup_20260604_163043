"use client"

import Link from "next/link"
import { usePathname, useRouter } from "next/navigation"
import {
  BanknotesIcon,
  ClipboardDocumentListIcon,
  Cog6ToothIcon,
  CubeIcon,
  HomeIcon,
  MapIcon,
  PowerIcon,
} from "@heroicons/react/24/outline"
import { supabase } from "../lib/supabaseClient"

const menuItems = [
  { name: "PDV", href: "/", icon: HomeIcon },
  { name: "Estoque", href: "/estoque", icon: CubeIcon },
  { name: "Frete", href: "/frete", icon: MapIcon },
  { name: "Orcamentos", href: "/orcamentos", icon: ClipboardDocumentListIcon },
  { name: "Caixa", href: "/caixa", icon: BanknotesIcon },
  { name: "Configuracoes", href: "/configuracoes", icon: Cog6ToothIcon },
]

export default function MenuLateral({
  aberto,
  onClose,
}: {
  aberto: boolean
  onClose: () => void
}) {
  const pathname = usePathname()
  const router = useRouter()

  async function fazerLogout() {
    await supabase.auth.signOut()
    onClose()
    router.replace("/login")
  }

  return (
    <>
      {aberto && (
        <button
          type="button"
          aria-label="Fechar menu"
          className="fixed inset-0 z-30 bg-slate-950/50 md:hidden"
          onClick={onClose}
        />
      )}

      <aside
        className={`fixed bottom-0 left-0 top-0 z-40 w-64 bg-[#17264a] text-white shadow-xl transition-transform duration-300 md:transition-all ${
          aberto ? "translate-x-0 md:w-64" : "-translate-x-full md:w-20 md:translate-x-0"
        }`}
      >
        <div className="flex h-full flex-col pt-20">
          <nav className="flex-1 space-y-1 px-2">
            {menuItems.map((item) => {
              const isActive = pathname === item.href
              const Icon = item.icon

              return (
                <Link
                  key={item.name}
                  href={item.href}
                  title={item.name}
                  onClick={onClose}
                  className={`flex min-h-12 items-center rounded-lg px-4 py-3 text-sm font-medium transition-colors ${
                    isActive ? "bg-[#c9a03d] text-white" : "text-slate-200 hover:bg-white/10"
                  } ${!aberto ? "md:justify-center" : ""}`}
                >
                  <Icon className="h-5 w-5 flex-shrink-0" />
                  <span className={`ml-3 truncate ${aberto ? "block" : "md:hidden"}`}>{item.name}</span>
                </Link>
              )
            })}
          </nav>
          <div className="px-2 pb-6">
            <button
              onClick={fazerLogout}
              title="Sair"
              className={`flex min-h-12 w-full items-center rounded-lg px-4 py-3 text-sm font-medium text-red-200 transition-colors hover:bg-red-600 hover:text-white ${
                !aberto ? "md:justify-center" : ""
              }`}
            >
              <PowerIcon className="h-5 w-5 flex-shrink-0" />
              <span className={`ml-3 ${aberto ? "block" : "md:hidden"}`}>Sair</span>
            </button>
          </div>
        </div>
      </aside>
    </>
  )
}

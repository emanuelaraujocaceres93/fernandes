"use client"

import { useEffect, useMemo, useState } from "react"
import { supabase } from "../lib/supabaseClient"
import { saveQuotePdf } from "../lib/pdf"
import { formatCurrency, normalizeText } from "../lib/format"
import type { Cliente, EmpresaConfig, ItemCarrinho, Produto } from "../lib/types"
import MateriaisOpcoes from "./components/MateriaisOpcoes"

export default function PDV() {
  const [produtos, setProdutos] = useState<Produto[]>([])
  const [carrinho, setCarrinho] = useState<ItemCarrinho[]>([])
  const [busca, setBusca] = useState("")
  const [nomeCliente, setNomeCliente] = useState("")
  const [clientes, setClientes] = useState<Cliente[]>([])
  const [loading, setLoading] = useState(false)
  const [erro, setErro] = useState("")
  const [sucesso, setSucesso] = useState("")
  const [config, setConfig] = useState<EmpresaConfig | null>(null)
  const [observacoes, setObservacoes] = useState("")
  const [opcionais, setOpcionais] = useState({
    garantia: false,
    entrega: false,
    manutencao: false,
    visita: false
  })
  const [materiaisSelecionados, setMateriaisSelecionados] = useState<any>({})
  const [mostrarMateriais, setMostrarMateriais] = useState(false)

  useEffect(() => {
    carregarDados()
  }, [])

  async function carregarDados() {
    const [produtosResult, clientesResult, configResult] = await Promise.all([
      supabase.from("produtos").select("*").order("nome"),
      supabase.from("clientes").select("*").order("nome"),
      supabase.from("configuracoes_empresa").select("*").limit(1).maybeSingle(),
    ])

    if (produtosResult.data) setProdutos(produtosResult.data as Produto[])
    if (clientesResult.data) setClientes(clientesResult.data as Cliente[])
    if (configResult.data) setConfig(configResult.data as EmpresaConfig)
    if (produtosResult.error || clientesResult.error) {
      setErro("NГЈo foi possГ­vel carregar todos os dados. Verifique sua conexГЈo.")
    }
  }

  const produtosFiltrados = useMemo(() => {
    const termo = busca.trim().toLowerCase()
    if (!termo) return produtos
    return produtos.filter((produto) => produto.nome.toLowerCase().includes(termo))
  }, [busca, produtos])

  // Calcular total do carrinho + materiais selecionados
  const totalMateriais = useMemo(() => {
    let total = 0
    Object.entries(materiaisSelecionados).forEach(([catId, itens]: [string, any]) => {
      Object.entries(itens).forEach(([itemId, selecionado]) => {
        if (selecionado) {
          const categorias: any = {
            tubulacao: { cobre_14: 45, cobre_38: 55, cobre_12: 65, cobre_58: 75, cobre_34: 85 },
            cabos: { cabopp_5x15: 120, cabopp_4x15: 95, cabopp_5x25: 180, cabopp_4x25: 145 },
            fixacao: { suporte_cond: 89.90, silver_tape: 12.50, bucha_s10: 1.50, parafuso_10: 2.00, bucha_s6: 1.00, parafuso_6: 1.50 },
            refrigeracao: { compressor: 850, filtro_secador: 45, valvula_schrader: 15, carga_gas: 250 },
            servicos: { higienizacao: 180, limpeza_filtro: 50, carnagem: 120, turbina: 150, reparos_eletricos: 100, troca_cabo: 80 }
          }
          total += categorias[catId]?.[itemId] || 0
        }
      })
    })
    return total
  }, [materiaisSelecionados])

  const totalCarrinho = useMemo(
    () => carrinho.reduce((acc, item) => acc + Number(item.valor_venda || 0) * item.quantidade, 0),
    [carrinho],
  )

  const totalGeral = totalCarrinho + totalMateriais
  const totalOpcionaisTela = (opcionais.garantia ? 150 : 0) + (opcionais.entrega ? 80 : 0) + (opcionais.manutencao ? 299 : 0) + (opcionais.visita ? 120 : 0)
  const totalGeralCompleto = totalGeral + totalOpcionaisTela

  function adicionarAoCarrinho(produto: Produto) {
    setCarrinho((atual) => {
      const existente = atual.find((item) => item.id === produto.id)
      if (!existente) return [...atual, { ...produto, quantidade: 1 }]
      return atual.map((item) =>
        item.id === produto.id ? { ...item, quantidade: item.quantidade + 1 } : item,
      )
    })
  }

  function removerDoCarrinho(produtoId: string) {
    setCarrinho((atual) => atual.filter((item) => item.id !== produtoId))
  }

  function atualizarQuantidade(produtoId: string, quantidade: number) {
    setCarrinho((atual) => {
      if (quantidade <= 0) return atual.filter((item) => item.id !== produtoId)
      return atual.map((item) => (item.id === produtoId ? { ...item, quantidade } : item))
    })
  }

  async function criarClienteSeNecessario() {
    const nome = normalizeText(nomeCliente)
    if (!nome) {
      setErro("Informe o nome do cliente.")
      return null
    }

    const existente = clientes.find((cliente) => cliente.nome.toLowerCase() === nome.toLowerCase())
    if (existente) return existente

    const { data: userData } = await supabase.auth.getUser()
    if (!userData.user) {
      setErro("SessГЈo expirada. Entre novamente.")
      return null
    }

    const { data, error } = await supabase
      .from("clientes")
      .insert({ nome, user_id: userData.user.id })
      .select()
      .single()

    if (error || !data) {
      setErro("NГЈo foi possГ­vel cadastrar o cliente.")
      return null
    }

    const cliente = data as Cliente
    setClientes((atual) => [...atual, cliente])
    return cliente
  }

  // Gerar lista de materiais selecionados para o PDF
  function getMateriaisSelecionadosTexto() {
    const itens: string[] = []
    const categorias: any = {
      tubulacao: { nome: "TubulaГ§ГЈo de Cobre", itens: { cobre_14: "Cobre de 1/4", cobre_38: "Cobre 3/8", cobre_12: "Cobre 1/2", cobre_58: "Cobre 5/8", cobre_34: "Cobre 3/4" } },
      cabos: { nome: "Cabos ElГ©tricos", itens: { cabopp_5x15: "Cabo PP 5 vias x 1,5mm", cabopp_4x15: "Cabo PP 4 vias x 1,5mm", cabopp_5x25: "Cabo PP 5 vias x 2,5mm", cabopp_4x25: "Cabo PP 4 vias x 2,5mm" } },
      fixacao: { nome: "FixaГ§ГЈo e Suportes", itens: { suporte_cond: "Suporte de condensadora", silver_tape: "Silver tape", bucha_s10: "Bucha S10", parafuso_10: "Parafuso 10 sextavado", bucha_s6: "Bucha S6", parafuso_6: "Parafuso 6 com arruela lisa" } },
      refrigeracao: { nome: "Componentes de RefrigeraГ§ГЈo", itens: { compressor: "Compressor", filtro_secador: "Filtro secador", valvula_schrader: "VГЎlvula Schrader", carga_gas: "Carga de gГЎs" } },
      servicos: { nome: "ServiГ§os Especializados", itens: { higienizacao: "HigienizaГ§ГЈo completa", limpeza_filtro: "Limpeza de filtro", carnagem: "Carnagem", turbina: "Troca/limpeza de turbina", reparos_eletricos: "Reparos elГ©tricos", troca_cabo: "Troca de cabo de comunicaГ§ГЈo" } }
    }

    Object.entries(materiaisSelecionados).forEach(([catId, itensObj]: [string, any]) => {
      Object.entries(itensObj).forEach(([itemId, selecionado]) => {
        if (selecionado && categorias[catId]?.itens[itemId]) {
          itens.push(`- ${categorias[catId].itens[itemId]}`)
        }
      })
    })
    return itens
  }

  async function gerarPDF() {
    setErro("")
    setSucesso("")

    if (carrinho.length === 0 && totalMateriais === 0) {
      setErro("Adicione pelo menos um item ao carrinho ou selecione materiais.")
      return
    }
    // Calcular opcionais
    const totalOpcionaisPDF = (opcionais.garantia ? 150 : 0) + (opcionais.entrega ? 80 : 0) + (opcionais.manutencao ? 299 : 0) + (opcionais.visita ? 120 : 0)
    const totalComOpcionais = totalGeral + totalOpcionaisPDF

    const cliente = await criarClienteSeNecessario()
    if (!cliente) return

    setLoading(true)

    try {
      const { data: userData } = await supabase.auth.getUser()
      if (!userData.user) throw new Error("SessГЈo expirada.")

      const { data: pedido, error: pedidoError } = await supabase
        .from("pedidos")
        .insert({
          cliente_id: cliente.id,
          total: totalComOpcionais,
          status: "pendente",
          user_id: userData.user.id,
        })
        .select()
        .single()

      if (pedidoError || !pedido) throw new Error(pedidoError?.message || "Erro ao salvar pedido.")

      const itens = carrinho.map((item) => ({
        pedido_id: pedido.id,
        produto_id: item.id,
        quantidade: item.quantidade,
        unitario: Number(item.valor_venda) || 0,
        total: (Number(item.valor_venda) || 0) * item.quantidade,
      }))

      if (itens.length > 0) {
        const { error: itensError } = await supabase.from("itens_pedido").insert(itens)
        if (itensError) throw new Error(itensError.message)
      }

      // Preparar linhas do PDF
      const linhasPDF = [
        ...carrinho.map(item => ({
          descricao: `${item.nome}${item.tipo === "servico" ? " (ServiГ§o)" : ""}`,
          quantidade: item.quantidade,
          unitario: Number(item.valor_venda) || 0,
          total: (Number(item.valor_venda) || 0) * item.quantidade
        })),
        ...getMateriaisSelecionadosTexto().map(material => ({
          descricao: material,
          quantidade: 1,
          unitario: 0,
          total: 0
        }))
      ]

      // CORREГ‡ГѓO AQUI: Definir o tipo explicitamente como array de tuplas [string, string]
      const detalhesAdicionais: Array<[string, string]> = [["Status", "Pendente"]]
      
      if (observacoes) {
        detalhesAdicionais.push(["ObservaГ§Гµes", observacoes])
      }
      if (totalMateriais > 0) {
        detalhesAdicionais.push(["Materiais adicionais", formatCurrency(totalMateriais)])
      }
      if (totalOpcionaisPDF > 0) {
        detalhesAdicionais.push(["Serviзos adicionais", formatCurrency(totalOpcionaisPDF)])
        if (opcionais.garantia) detalhesAdicionais.push(["  • Garantia estendida", "R$ 150,00"])
        if (opcionais.entrega) detalhesAdicionais.push(["  • Entrega expressa", "R$ 80,00"])
        if (opcionais.manutencao) detalhesAdicionais.push(["  • Plano de manutenзгo", "R$ 299,00"])
        if (opcionais.visita) detalhesAdicionais.push(["  • Visita tйcnica", "R$ 120,00"])
      }

      saveQuotePdf(
        {
          titulo: "OrГ§amento",
          numero: pedido.numero_unico,
          cliente: cliente.nome,
          config,
          linhas: linhasPDF,
          total: totalComOpcionais,
          detalhes: detalhesAdicionais,
        },
        `orcamento_${pedido.numero_unico || pedido.id}.pdf`,
      )

      setCarrinho([])
      setNomeCliente("")
      setObservacoes("")
      setMateriaisSelecionados({})
      setMostrarMateriais(false)
      setSucesso("OrГ§amento salvo e PDF gerado com sucesso!")
    } catch (error) {
      setErro(error instanceof Error ? error.message : "Erro ao gerar orГ§amento.")
    } finally {
      setLoading(false)
    }
  }

  return (
    <div className="space-y-6">
      <div className="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p className="text-sm font-medium uppercase tracking-wide text-[#c9a03d]">PDV</p>
          <h1 className="text-2xl font-bold text-[#17264a]">Venda e orГ§amento</h1>
        </div>
        <div className="rounded-lg bg-white px-4 py-3 shadow-sm ring-1 ring-slate-200">
          <p className="text-xs uppercase text-slate-500">Total atual</p>
          <p className="text-2xl font-bold text-[#c9a03d]">{formatCurrency(totalGeral)}</p>
        </div>
      </div>

      {(erro || sucesso) && (
        <div className={`rounded-lg p-3 text-sm ${erro ? "bg-red-50 text-red-700" : "bg-green-50 text-green-700"}`}>
          {erro || sucesso}
        </div>
      )}

      <div className="grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1fr)_420px]">
        <section className="rounded-lg bg-white p-4 shadow-sm ring-1 ring-slate-200">
          <div className="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <h2 className="text-lg font-semibold text-[#17264a]">Produtos e serviГ§os</h2>
            <input
              type="search"
              placeholder="Buscar item"
              className="w-full rounded-lg border border-slate-300 px-3 py-2 outline-none focus:border-[#17264a] focus:ring-2 focus:ring-[#17264a]/10 sm:max-w-xs"
              value={busca}
              onChange={(e) => setBusca(e.target.value)}
            />
          </div>

          {/* BotГЈo para mostrar/ocultar materiais */}
          <div className="mb-4">
            <button
              onClick={() => setMostrarMateriais(!mostrarMateriais)}
              className="w-full mb-2 rounded-lg bg-[#c9a03d] px-4 py-2 font-semibold text-white hover:bg-[#b58d2c]"
            >
              {mostrarMateriais ? "рџ“¦ Ocultar materiais" : "рџ”§ Adicionar materiais e serviГ§os"}
            </button>
            
            {mostrarMateriais && (
              <div className="mt-4 p-4 bg-gray-50 rounded-lg border">
                <MateriaisOpcoes 
                  onSelecionadosChange={setMateriaisSelecionados}
                  initialSelecionados={materiaisSelecionados}
                />
              </div>
            )}
                    {/* PRODUTOS DE EXEMPLO PARA ADIЗГO RБPIDA */}
          <div className="mt-4">
            <label className="block text-sm font-medium text-gray-700 mb-2">
              ? Adicionar produtos rбpidos:
            </label>
            <div className="flex flex-wrap gap-2">
              <button onClick={() => adicionarAoCarrinho({ id: "temp_compressor", nome: "Compressor novo compatнvel", valor_venda: 224, tipo: "produto" } as any)} className="px-2 py-1 bg-green-100 text-green-700 rounded text-xs hover:bg-green-200">+ Compressor (R$ 224)</button>
              <button onClick={() => adicionarAoCarrinho({ id: "temp_instalacao", nome: "Instalaзгo do compressor", valor_venda: 150, tipo: "servico" } as any)} className="px-2 py-1 bg-blue-100 text-blue-700 rounded text-xs hover:bg-blue-200">+ Instalaзгo (R$ 150)</button>
              <button onClick={() => adicionarAoCarrinho({ id: "temp_limpeza", nome: "Limpeza completa com fluido 141b", valor_venda: 120, tipo: "servico" } as any)} className="px-2 py-1 bg-purple-100 text-purple-700 rounded text-xs hover:bg-purple-200">+ Limpeza (R$ 120)</button>
              <button onClick={() => adicionarAoCarrinho({ id: "temp_gas", nome: "Gбs refrigerante R-410A (kg)", valor_venda: 89, tipo: "produto" } as any)} className="px-2 py-1 bg-yellow-100 text-yellow-700 rounded text-xs hover:bg-yellow-200">+ Gбs R-410A (R$ 89)</button>
              <button onClick={() => adicionarAoCarrinho({ id: "temp_filtro", nome: "Filtro de linha para AC", valor_venda: 45, tipo: "produto" } as any)} className="px-2 py-1 bg-orange-100 text-orange-700 rounded text-xs hover:bg-orange-200">+ Filtro (R$ 45)</button>
            </div>
          </div>

           gap-3 overflow-y-auto pr-1 sm:grid-cols-2">
            {produtosFiltrados.map((produto) => (
              <button
                key={produto.id}
                onClick={() => adicionarAoCarrinho(produto)}
                className="rounded-lg border border-slate-200 p-4 text-left transition hover:border-[#c9a03d] hover:bg-amber-50/40"
              >
                <div className="flex items-start justify-between gap-3">
                  <div>
                    <p className="font-semibold text-slate-900">{produto.nome}</p>
                    <p className="mt-1 text-xs uppercase text-slate-500">
                      {produto.tipo === "servico" ? "ServiГ§o" : "Produto"}
                    </p>
                  </div>
                  <span className="font-bold text-[#17264a]">{formatCurrency(produto.valor_venda)}</span>
                </div>
              </button>
            ))}
            {produtosFiltrados.length === 0 && (
              <div className="rounded-lg border border-dashed border-slate-300 p-8 text-center text-sm text-slate-500 sm:col-span-2">
                Nenhum item encontrado.
              </div>
            )}
          </div>
        </section>

        <section className="rounded-lg bg-white p-4 shadow-sm ring-1 ring-slate-200">
          <h2 className="mb-4 text-lg font-semibold text-[#17264a]">Carrinho</h2>
          <input
            type="text"
            placeholder="Nome do cliente *"
            className="mb-4 w-full rounded-lg border border-slate-300 px-3 py-2 outline-none focus:border-[#17264a] focus:ring-2 focus:ring-[#17264a]/10"
            value={nomeCliente}
            onChange={(e) => setNomeCliente(e.target.value)}
            maxLength={120}
          />

          {/* Campo de observaГ§Гµes */}
          <div className="mb-4">
            <label className="block text-sm font-medium text-gray-700 mb-1">
              рџ“ќ ObservaГ§Гµes do orГ§amento
            </label>
            <textarea
              value={observacoes}
              onChange={(e) => setObservacoes(e.target.value)}
              placeholder="Adicione observaГ§Гµes importantes para o cliente (ex: prazo de entrega, garantia, etc.)..."
              className="w-full rounded-lg border border-slate-300 px-3 py-2 outline-none focus:border-[#17264a] focus:ring-2 focus:ring-[#17264a]/10"
              rows={3}
            />
          </div>

          <div className="mb-4 max-h-[35vh] space-y-3 overflow-y-auto pr-1">
            {carrinho.map((item) => (
              <div key={item.id} className="rounded-lg border border-slate-200 p-3">
                <div className="flex items-start justify-between gap-3">
                  <div>
                    <p className="font-medium">{item.nome}</p>
                    <p className="text-sm text-slate-500">{formatCurrency(item.valor_venda)}</p>
                  </div>
                  <button
                    onClick={() => removerDoCarrinho(item.id)}
                    className="rounded-md px-2 py-1 text-sm text-red-600 hover:bg-red-50"
                    aria-label={`Remover ${item.nome}`}
                  >
                    Remover
                  </button>
                </div>
                <div className="mt-3 flex items-center justify-between">
                  <div className="flex items-center rounded-lg border border-slate-200">
                    <button className="px-3 py-1" onClick={() => atualizarQuantidade(item.id, item.quantidade - 1)}>
                      -
                    </button>
                    <span className="min-w-8 text-center text-sm font-semibold">{item.quantidade}</span>
                    <button className="px-3 py-1" onClick={() => atualizarQuantidade(item.id, item.quantidade + 1)}>
                      +
                    </button>
                  </div>
                  <span className="font-semibold">{formatCurrency(item.valor_venda * item.quantidade)}</span>
                </div>
              </div>
            ))}
            {carrinho.length === 0 && totalMateriais === 0 && (
              <div className="rounded-lg border border-dashed border-slate-300 p-8 text-center text-sm text-slate-500">
                Selecione itens ou materiais para montar o orГ§amento.
              </div>
            )}
          </div>

          {/* Resumo com materiais adicionais */}
          <div className="border-t border-slate-200 pt-4">
            {totalMateriais > 0 && (
              <div className="mb-2 flex items-center justify-between text-sm">
                <span className="text-slate-600">Subtotal produtos:</span>
                <span>{formatCurrency(totalCarrinho)}</span>
              </div>
            )}
            {totalMateriais > 0 && (
              <div className="mb-2 flex items-center justify-between text-sm">
                <span className="text-slate-600">Materiais adicionais:</span>
                <span>{formatCurrency(totalMateriais)}</span>
              </div>
            )}
            <div className="mb-4 flex items-center justify-between">
              <span className="text-sm font-medium text-slate-600">Total geral</span>
              <span className="text-2xl font-bold text-[#c9a03d]">{formatCurrency(totalGeral)}</span>
            </div>
            <button
              onClick={gerarPDF}
              disabled={loading || (carrinho.length === 0 && totalMateriais === 0) || !nomeCliente.trim()}
              className="w-full rounded-lg bg-[#17264a] py-3 font-semibold text-white transition hover:bg-[#24375f] disabled:cursor-not-allowed disabled:opacity-50"
            >
              {loading ? "Gerando..." : "рџ“„ Gerar orГ§amento PDF"}
            </button>
          </div>
        </section>
      </div>
    </div>
  )
}